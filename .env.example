# Copy this file to .env and point it at your intranet services.
# `.env` is loaded automatically by kb.py and is ignored by git.

LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=
LOCAL_OPENAI_CHAT_MODEL=local-chat-model

# Required only for semantic retrieval.
# Use an OpenAI-compatible /embeddings service, or set LOCAL_EMBEDDING_CMD.
# If your company does not provide an embedding API, prefer LOCAL_EMBEDDING_CMD.
LOCAL_OPENAI_EMBEDDING_MODEL=local-embedding-model
# LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:8000/v1
# LOCAL_EMBEDDING_API_KEY=
# LOCAL_EMBEDDING_CMD=python tools/embed_sentence_transformers.py
# LOCAL_EMBEDDING_CMD=python tools/embed_flagembedding_bgem3.py
# LOCAL_EMBEDDING_CMD=node tools/embed_transformersjs.mjs
# LOCAL_EMBEDDING_MODEL_PATH=models/bge-m3
LOCAL_EMBEDDING_LOCAL_FILES_ONLY=true
LOCAL_EMBEDDING_NORMALIZE=true
LOCAL_EMBEDDING_BATCH_SIZE=16

# PDF extraction backends:
# auto = pdfplumber, then pdfminer, then pypdf, then pdftotext.
# command = run PDF_EXTRACTOR_CMD and read stdout.
PDF_EXTRACTOR=auto
# PDF_EXTRACTOR_CMD=python tools/pdf_to_text.py {input}
PDF_EXTRACT_TIMEOUT=300
PDF_MIN_TEXT_CHARS=80
